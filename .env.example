# Copy to .env and fill in. The council reads these at runtime.

# Required: your free OpenRouter key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: route through a different OpenAI-compatible endpoint instead of
# OpenRouter — e.g. a FreeLLMAPI gateway. Just point this at its /v1 URL.
# OPENAI_BASE_URL=http://localhost:8787/v1

# Optional: override the panel (comma-separated model ids).
# COUNCIL_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-coder:free
